<Window x:Class="AlgoRunner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AlgoRunner.Models"
        Title="AlgoRunner — C++ 算法学习工具"
        Height="740" Width="1160" MinHeight="500" MinWidth="800"
        Background="#1E1E1E" Foreground="#D4D4D4"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Button style -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#0E639C"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="12,6"/>
            <Setter Property="Margin"       Value="4,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1177BB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#333"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#6B2020"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B3030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TreeView item style: dark background, hover highlight -->
        <Style TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="2,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  Width="12" Height="12" Margin="1,0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" Focusable="False"
                                                  Background="Transparent" BorderThickness="0"
                                                  Foreground="#888">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent">
                                                                <Path x:Name="arrow" Data="M 0 0 L 4 4 L 0 8 Z"
                                                                      Fill="#888" Margin="2,0"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="arrow" Property="Data"
                                                                            Value="M 0 0 L 8 0 L 4 4 Z"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="14,0,0,0"
                                            Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"   Value="False"/>
                                    <Condition Property="IsMouseOver"  Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                            </MultiTrigger>
                            <!-- Hide expander arrow for leaf nodes -->
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="180"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ Left panel: file tree ══════════════ -->
        <DockPanel Grid.Row="0" Grid.Column="0" Background="#252526">

            <!-- Section header -->
            <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="10,7">
                <TextBlock Text="算法文件" FontWeight="SemiBold" FontSize="13"
                           Foreground="#BBBBBB"/>
            </Border>

            <!-- Search box with placeholder -->
            <Border DockPanel.Dock="Top" Background="#3C3C3C" Margin="6,6,6,4"
                    CornerRadius="3" BorderBrush="#555" BorderThickness="1">
                <Grid>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent" Foreground="#CCCCCC"
                             BorderThickness="0" Padding="6,4"
                             FontSize="12" CaretBrush="White"
                             TextChanged="SearchBox_TextChanged"/>
                    <TextBlock x:Name="SearchPlaceholder" Text="🔍 搜索文件..."
                               Foreground="#666" Margin="7,4,0,0" FontSize="12"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <!-- Any non-empty text hides the placeholder -->
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- File tree -->
            <TreeView x:Name="FileTree" Background="#252526" BorderThickness="0"
                      Foreground="#CCCCCC" Padding="4"
                      SelectedItemChanged="FileTree_SelectedItemChanged">
                <TreeView.Resources>
                    <!-- Directory node -->
                    <HierarchicalDataTemplate DataType="{x:Type models:DirectoryNode}"
                                              ItemsSource="{Binding Algorithms}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <TextBlock Text="📂 " FontSize="13"/>
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <HierarchicalDataTemplate DataType="{x:Type models:AlgorithmNode}"
                                              ItemsSource="{Binding Files}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <TextBlock Text="🧩 " FontSize="12" Foreground="#DCDCAA"/>
                            <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#DCDCAA"/>
                        </StackPanel>
                    </HierarchicalDataTemplate>

                    <!-- .cpp file leaf -->
                    <DataTemplate DataType="{x:Type models:CppFile}">
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <TextBlock Text="⚙ " FontSize="12" Foreground="#4EC9B0"/>
                            <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Row="0" Grid.Column="1" Width="4"
                      Background="#333" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Cursor="SizeWE"/>

        <!-- ══════════════ Right panel ══════════════ -->
        <DockPanel Grid.Row="0" Grid.Column="2" Background="#1E1E1E">

            <!-- Info bar: selected file + compiler -->
            <Border DockPanel.Dock="Top" Background="#252526" Padding="12,7"
                    BorderBrush="#333" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="SelectedFileLabel" Grid.Column="0"
                               Text="← 从左侧选择一个 .cpp 文件"
                               FontSize="13" Foreground="#9CDCFE"
                               FontFamily="Consolas" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="编译器: " FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CompilerLabel" Text="检测中..."
                                   FontSize="11" Foreground="#4EC9B0" VerticalAlignment="Center"/>
                        <Button x:Name="BrowseCompilerBtn" Content="···" Width="28" Height="20"
                                Margin="6,0,0,0" Click="BrowseCompilerBtn_Click"
                                Style="{StaticResource SecondaryBtn}"
                                ToolTip="手动指定编译器路径（g++ 或 cl.exe）"
                                FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Action buttons -->
            <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="8,6"
                    BorderBrush="#444" BorderThickness="0,0,0,1">
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="RunBtn"     Content="▶  编译并运行"   MinWidth="115"
                            Style="{StaticResource PrimaryBtn}"    Click="RunBtn_Click"     IsEnabled="False"/>
                    <Button x:Name="CompileBtn" Content="🔨  仅编译"       MinWidth="90"
                            Style="{StaticResource SecondaryBtn}"  Click="CompileBtn_Click" IsEnabled="False"/>
                    <Button x:Name="DebugBtn"   Content="🐛  VS Code 调试" MinWidth="125"
                            Style="{StaticResource SecondaryBtn}"  Click="DebugBtn_Click"   IsEnabled="False"/>
                    <Button x:Name="OpenBtn"    Content="📄  打开文件"     MinWidth="90"
                            Style="{StaticResource SecondaryBtn}"  Click="OpenBtn_Click"    IsEnabled="False"/>
                    <Separator Width="1" Background="#555" Margin="8,4"/>
                    <Button x:Name="StopBtn"    Content="⬛  停止"         MinWidth="75"
                            Style="{StaticResource DangerBtn}"     Click="StopBtn_Click"    IsEnabled="False"/>
                    <Button x:Name="ClearBtn"   Content="🗑  清空"         MinWidth="75"
                            Style="{StaticResource SecondaryBtn}"  Click="ClearBtn_Click"/>
                </WrapPanel>
            </Border>

            <!-- Output area -->
            <ScrollViewer x:Name="OutputScroll" Background="#1E1E1E"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <RichTextBox x:Name="OutputBox"
                             Background="Transparent" Foreground="#D4D4D4"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="13" IsReadOnly="True"
                             BorderThickness="0" Padding="10,8"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </DockPanel>

        <!-- ══════════════ Status bar ══════════════ -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Background="#007ACC" Padding="10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0"
                           Text="就绪" Foreground="White"
                           FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="FileCountLabel" Grid.Column="1"
                           Text="" Foreground="White"
                           FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
